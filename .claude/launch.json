{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8080
    },
    {
      "name": "vite-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173
    },
    {
      "name": "vercel-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vercel", "dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "vite-direct",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "8080"],
      "port": 8080
    }
  ]
}
